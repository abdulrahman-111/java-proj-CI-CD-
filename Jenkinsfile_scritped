node("agent01"){
def jdk_java_path = tool name: 'jdk-11', type: 'jdk' // tool is function return the path of intallation or binaries
def mvn_java_path= tool name: 'maven-3-5-4', type: 'maven'

env.PATH= "${mvn_java_path}/bin:${jdk_java_path}:${env.PATH}"



// we need to check out the code -> not like the declaritive 

    stage("checkout SCM"){
        git branch: 'main', url: 'https://github.com/abdulrahman-111/java-proj-CI-CD-'
    }
    stage('Build the app') {
        sh 'mvn clean package -DskipTests'
    }
    stage("test the app "){ 
        sh "mvn  test"
        
    }

    stage("Build the image "){
       
        sh "docker build -t abdulrahman011/java-app:v${BUILD_NUMBER}   ."
        
    }
